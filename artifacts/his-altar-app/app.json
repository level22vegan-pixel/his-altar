{
  "expo": {
    "name": "His Altar",
    "slug": "his-altar-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "his-altar-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/altar-splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0c0a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hisaltar.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hisaltar.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e3eed360-626e-4675-b24f-9552d775ead5"
      }
    },
    "owner": "22vegan"
  }
}
