{
  "expo": {
    "name": "His Altar",
    "slug": "his-altar-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "his-altar-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/altar-splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0c0a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hisaltar.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "His Altar sends push notifications for team updates and ministry alerts.",
        "NSFaceIDUsageDescription": "His Altar uses Face ID to securely unlock admin features.",
        "NSCameraUsageDescription": "His Altar uses the camera for worker profile photos.",
        "NSLocalNetworkUsageDescription": "His Altar connects to the ministry server on your local network.",
        "ITSPrivacyPolicyURL": "https://hisaltar.app/privacy"
      }
    },
    "android": {
      "package": "com.hisaltar.app",
      "permissions": [
        "android.permission.USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7c3aed",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "His Altar",
          "iosDisplayInForeground": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "dab97a32-2c2b-4ad4-bb3b-342e117b1415"
      }
    }
  }
}
